---
import { site } from '../site.config';
import { withBase } from '../utils/base';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const navItems = [
  { href: withBase(), label: 'Blog' },
  { href: withBase('about'), label: 'About' },
  { href: withBase('contact/'), label: 'Contact' },
];

function isActive(href: string): boolean {
  const normalizedPath = currentPath.endsWith('/') ? currentPath : `${currentPath}/`;
  const normalizedHref = href.endsWith('/') ? href : `${href}/`;
  if (href === withBase()) {
    return normalizedPath === normalizedHref || normalizedPath.includes('/blog/');
  }
  return normalizedPath === normalizedHref || normalizedPath.startsWith(normalizedHref);
}
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={withBase()} class="site-title">
      <span class="site-title__gear" aria-hidden="true">
        <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g class="gear-rotor">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M22.5 3.5h-5l-.9 4.3a12.6 12.6 0 0 0-3.4 1.4l-3.7-2.4-3.5 3.5 2.4 3.7a12.6 12.6 0 0 0-1.4 3.4L2.7 18.3v5l4.3.9c.3 1.2.8 2.3 1.4 3.4L6 31.3l3.5 3.5 3.7-2.4c1.1.6 2.2 1.1 3.4 1.4l.9 4.3h5l.9-4.3a12.6 12.6 0 0 0 3.4-1.4l3.7 2.4 3.5-3.5-2.4-3.7c.6-1.1 1.1-2.2 1.4-3.4l4.3-.9v-5l-4.3-.9a12.6 12.6 0 0 0-1.4-3.4l2.4-3.7-3.5-3.5-3.7 2.4a12.6 12.6 0 0 0-3.4-1.4l-.9-4.3Zm-2.5 24a6.7 6.7 0 1 0 0-13.4 6.7 6.7 0 0 0 0 13.4Z"
              fill="currentColor"
            />
          </g>
          <circle cx="20" cy="20.8" r="3" fill="var(--color-accent)" />
        </svg>
      </span>
      {site.title}
    </a>
    <nav aria-label="Main navigation">
      <ul class="site-nav">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <ThemeToggle />
        </li>
      </ul>
    </nav>
  </div>
</header>
