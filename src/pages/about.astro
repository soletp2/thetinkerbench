---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';
import { withBase } from '../utils/base';

const focusAreas = [
  'Developer documentation and API references',
  'Docs-as-code and CI/CD pipelines',
  'AI agents for documentation automation',
  'Information architecture and content design',
  'Regulated documentation (ISO 13485) and process',
];

const highlights = [
  {
    label: 'Role',
    value: 'Senior documentation engineer at GridDynamics',
  },
  {
    label: 'Focus',
    value: 'Docs-as-code pipelines and AI-driven automation',
  },
  {
    label: 'Background',
    value: 'Applied linguistics · regulated med-tech docs · team leadership',
  },
];
---

<BaseLayout
  title="About"
  description={`About ${site.author} and ${site.title} — AI tools, automation, and developer documentation.`}
>
  <div class="content">
    <div class="page-card about-page">
      <header class="about-hero">
        <span class="hero__badge">Documentation engineer · Technical writer</span>
        <h1>{site.author}</h1>
        <p class="about-hero__lead">
          Hi, I'm Pavlo — I run {site.title}, where I build docs-as-code tooling,
          automate developer documentation, and write about what I learn along the way.
        </p>
      </header>

      <div class="about-highlights" aria-label="At a glance">
        {highlights.map((item) => (
          <div class="about-highlights__item">
            <p class="about-highlights__label">{item.label}</p>
            <p class="about-highlights__value">{item.value}</p>
          </div>
        ))}
      </div>

      <section class="about-section">
        <h2>Background</h2>
        <p>
          I didn't start in technical writing. I began in marketing and copywriting at
          EngSchool, producing content plans, commercial scripts, and blog posts. That work
          taught me how to write for an audience — but I wanted something more structured
          and technical.
        </p>
        <p>
          I found that at GlobalLogic, where I spent nearly four years on regulated medical
          robotics documentation: Design Specification Documents, System Requirement
          Specifications, validation plans, and test documentation to ISO 13485 standards.
          I also led a cross-functional team of 14 software developers as project manager.
        </p>
        <p>
          Along the way I took on part-time technical writing at Mate Academy, creating
          educational content for Python, Java, JavaScript, DevOps, and QA courses. I built
          a unified style guide and streamlined the review process — my first real docs-as-code
          experience with Markdown and Git.
        </p>
        <p>
          In 2025 I moved into senior documentation engineering at GridDynamics. Documentation
          engineering turned out to combine everything I care about: clear writing, software
          tooling, and making developers' lives easier.
        </p>
      </section>

      <section class="about-section">
        <h2>Current work</h2>
        <p>
          I own developer documentation end-to-end — from getting-started guides and
          conceptual docs through OpenAPI references and long-term maintenance. I also build
          the docs-as-code toolchain that keeps documentation accurate as product velocity
          scales.
        </p>
        <p>
          My main project is an AI-driven pipeline integrated into CI/CD. On every build
          across roughly 120 microservices, the pipeline regenerates developer documentation
          so references stay in sync with the codebase.
        </p>
        <ul class="about-list">
          <li>
            A custom Gradle plugin auto-generates OpenAPI contracts from annotated Java code
            across 85 REST services.
          </li>
          <li>
            Five AI-agent capabilities handle README generation, architecture diagramming,
            portal publishing, requirements extraction, and AGENT.md authoring.
          </li>
          <li>
            Guardrails for concurrency, loop prevention, and token quotas keep automated
            docs safe to run on every CI execution.
          </li>
        </ul>
      </section>

      <section class="about-section">
        <h2>Education</h2>
        <p>
          I earned a B.A. in Applied Linguistics from Lviv Polytechnic University (2024)
          and completed a summer program at Diablo Valley College in California (2021).
        </p>
        <p>
          The linguistics background carries over directly: applied linguistics is the study
          of how language functions in real contexts — which is what information architecture
          and technical content design are about.
        </p>
      </section>

      <section class="about-section">
        <h2>Leadership and community</h2>
        <p>
          At GlobalLogic I led a team of 14 developers through the full project lifecycle —
          translating client needs into structured work, defending proposals, and keeping
          everyone aligned with ISO 13485 requirements.
        </p>
        <p>
          Outside of work, I served as project manager for Pobachymos Foundation (May 2023 –
          March 2024), organizing charity auctions across Ukraine.
        </p>
        <p>
          I speak English (full professional proficiency), Ukrainian (native), and German
          (limited working proficiency).
        </p>
      </section>

      <section class="about-section">
        <h2>What I write about</h2>
        <p class="about-section__intro">
          On this site I share notes on the topics below — experiments, tooling, and lessons
          from building documentation systems in production.
        </p>
        <ul class="about-tags">
          {focusAreas.map((area) => (
            <li><span class="tag">{area}</span></li>
          ))}
        </ul>
      </section>

      <section class="about-section about-section--cta">
        <h2>Get in touch</h2>
        <p>
          Questions about documentation engineering, docs-as-code pipelines, or AI-driven
          automation? I'd like to hear from you.
        </p>
        <div class="about-cta">
          <a href={withBase('contact/')} class="btn btn--primary">Contact me</a>
          <a href={`mailto:${site.email}`} class="btn btn--ghost">{site.email}</a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
