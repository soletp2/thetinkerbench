---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { site } from '../site.config';
import { withBase } from '../utils/base';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title={site.title}
  description="Notes on building AI tools, automating workflows, and learning software development in public."
>
  <div class="content">
    <header class="hero">
      <span class="hero__badge">{site.tagline}</span>
      <h1>{site.title}</h1>
      <p class="hero__lead">
        A workshop for experiments — AI-assisted tools, process automation, docs-as-code pipelines,
        and the software craft behind useful solutions.
      </p>
      <div class="hero__actions">
        <a href={withBase('about/')} class="btn btn--primary">About me</a>
        <a href={withBase('contact/')} class="btn btn--ghost">Get in touch</a>
      </div>
    </header>

    <section aria-label="Blog posts">
      <div class="section-header">
        <h2>Latest writing</h2>
        <span class="section-header__count">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
      </div>
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>
