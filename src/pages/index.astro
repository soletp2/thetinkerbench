---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { site } from '../site.config';
import { withBase } from '../utils/base';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title={site.title}
  description="Notes on building AI tools, automating workflows, and learning software development in public."
>
  <div class="content">
    <header class="hero">
      <div class="hero__layout">
        <div>
          <span class="hero__badge">{site.tagline}</span>
          <h1>{site.title}</h1>
          <p class="hero__lead">
            A workshop for experiments — AI-assisted tools, process automation, docs-as-code
            pipelines, and the software craft behind useful solutions.
          </p>
          <div class="hero__actions">
            <a href={withBase('about/')} class="btn btn--primary">About me</a>
            <a href={withBase('contact/')} class="btn btn--ghost">Get in touch</a>
          </div>
        </div>
        <div class="hero__art" aria-hidden="true">
          <svg viewBox="0 0 320 220" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- blueprint registration marks -->
            <g stroke="currentColor" stroke-width="1.5" opacity="0.4">
              <path d="M28 22v12M22 28h12" />
              <path d="M292 142v12M286 148h12" />
              <path d="M60 130v8M56 134h8" />
            </g>

            <!-- chip + circuit trace + LED -->
            <rect x="30" y="74" width="38" height="38" rx="4" stroke="currentColor" stroke-width="2.5" />
            <rect x="40" y="84" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2" opacity="0.6" />
            <g stroke="currentColor" stroke-width="2" opacity="0.6">
              <path d="M38 74v-8M49 74v-8M60 74v-8" />
              <path d="M38 112v8M49 112v8M60 112v8" />
            </g>
            <path
              class="trace"
              d="M68 93h36v-34h32"
              stroke="var(--color-accent)"
              stroke-width="2.5"
              stroke-linecap="round"
            />
            <circle class="led" cx="142" cy="59" r="5.5" fill="var(--color-accent)" />
            <circle cx="142" cy="59" r="10" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.35" />

            <!-- meshing gears -->
            <g class="gear-large" stroke="currentColor" stroke-width="3">
              <g fill="var(--color-bg)">
                <rect x="173" y="56" width="10" height="14" rx="2" />
                <rect x="173" y="56" width="10" height="14" rx="2" transform="rotate(45 178 96)" />
                <rect x="173" y="56" width="10" height="14" rx="2" transform="rotate(90 178 96)" />
                <rect x="173" y="56" width="10" height="14" rx="2" transform="rotate(135 178 96)" />
                <rect x="173" y="56" width="10" height="14" rx="2" transform="rotate(180 178 96)" />
                <rect x="173" y="56" width="10" height="14" rx="2" transform="rotate(225 178 96)" />
                <rect x="173" y="56" width="10" height="14" rx="2" transform="rotate(270 178 96)" />
                <rect x="173" y="56" width="10" height="14" rx="2" transform="rotate(315 178 96)" />
              </g>
              <circle cx="178" cy="96" r="29" fill="var(--color-bg)" />
              <circle cx="178" cy="96" r="9" fill="var(--color-accent-soft)" />
            </g>
            <g class="gear-small" stroke="var(--color-brass)" stroke-width="2.5">
              <g fill="var(--color-bg)">
                <rect x="234" y="34" width="8" height="11" rx="2" />
                <rect x="234" y="34" width="8" height="11" rx="2" transform="rotate(60 238 62)" />
                <rect x="234" y="34" width="8" height="11" rx="2" transform="rotate(120 238 62)" />
                <rect x="234" y="34" width="8" height="11" rx="2" transform="rotate(180 238 62)" />
                <rect x="234" y="34" width="8" height="11" rx="2" transform="rotate(240 238 62)" />
                <rect x="234" y="34" width="8" height="11" rx="2" transform="rotate(300 238 62)" />
              </g>
              <circle cx="238" cy="62" r="17" fill="var(--color-bg)" />
              <circle cx="238" cy="62" r="5.5" fill="var(--color-accent-soft)" />
            </g>

            <!-- bench top -->
            <path d="M12 172h296" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
            <path d="M30 176v22M290 176v22" stroke="currentColor" stroke-width="3" stroke-linecap="round" opacity="0.7" />

            <!-- ruler on the bench -->
            <g>
              <rect x="46" y="154" width="118" height="14" rx="2" stroke="var(--color-brass)" stroke-width="2" />
              <g stroke="var(--color-brass)" stroke-width="1.5" opacity="0.8">
                <path d="M60 154v6M74 154v9M88 154v6M102 154v9M116 154v6M130 154v9M144 154v6" />
              </g>
            </g>

            <!-- screwdriver on the bench -->
            <g>
              <rect x="200" y="156" width="34" height="12" rx="5" fill="var(--color-accent)" opacity="0.85" />
              <path d="M234 162h44" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
              <path d="M278 159.5v5l10 -1v-3z" fill="currentColor" />
            </g>
          </svg>
        </div>
      </div>
    </header>

    <section aria-label="Blog posts">
      <div class="section-header">
        <h2>Bench log</h2>
        <span class="section-header__count">{posts.length} {posts.length === 1 ? 'entry' : 'entries'}</span>
      </div>
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>
